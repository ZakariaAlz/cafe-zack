{
  "mcpServers": {
    "github": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-c",
        "exec docker run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN=\"$(/snap/bin/gh auth token)\" ghcr.io/github/github-mcp-server"
      ]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "bunx",
      "args": ["chrome-devtools-mcp@latest"]
    },
    "playwright": {
      "type": "stdio",
      "command": "bunx",
      "args": ["@playwright/mcp@latest"]
    }
  }
}
