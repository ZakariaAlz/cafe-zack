# Café Zack — environment template
# Copy to .env.local and fill in. Never commit .env.local.
#
# These are added as we wire features in later phases.
# Phase 0 needs no env vars to run `bun dev`.

# Public site URL (used for OG images, canonical URLs, sitemap)
# NEXT_PUBLIC_SITE_URL=https://zackalizouaoui.dev

# Phase 5 — lead form + contact (Resend, REST API only, edge-safe)
# RESEND_API_KEY=
# RESEND_TO_EMAIL=zakariaalizouaoui.dev@gmail.com
# RESEND_FROM_EMAIL=hello@zackalizouaoui.dev

# Phase 5 — lead storage + analytics (Supabase, edge-safe SDK)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # server-only, never expose to client

# Phase 5 — newsletter (Buttondown or Resend Audiences)
# BUTTONDOWN_API_KEY=

# Phase 7 — error monitoring
# NEXT_PUBLIC_SENTRY_DSN=
