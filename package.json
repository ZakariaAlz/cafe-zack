    "@react-three/rapier": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "howler": "^2.2.4",
    "lenis": "^1.3.23",
    "leva": "^0.10.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
